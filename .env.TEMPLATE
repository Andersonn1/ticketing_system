# General Settings
APP_NAME="IT Support System"
APP_ENV=develop
LOG_FILE=logs/app.log
LOG_LEVEL=DEBUG
LOG_FILE_ROTATION="3 days"
SESSION_KEY=dev-session-key
# LLM Settings
